      `SELECT COUNT(*) + 1 as posicion
       FROM leaderboard l
       INNER JOIN users u ON l.user_id = u.id
       WHERE u.rol = 'estudiante' AND u.activo = true 
       AND l.xp_total > (SELECT xp_total FROM leaderboard WHERE user_id = $1)`,
